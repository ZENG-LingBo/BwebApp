# ── LLM (OpenAI-compatible proxy) ──
LLM_API_BASE=https://new.lemonapi.site/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=gemini-3.1-pro-preview

# ── Server ──
# On Railway, leave PORT unset and let the platform inject it. Locally this
# defaults to 3001 if omitted.
PORT=3001

# ── Storage (optional — only set in production / on Railway) ──
# When deploying with a persistent volume, point these at the mount.
# Default (dev / unset): ./server/data/stories.db and ./server/videos
# Railway volume example (mount the volume at /app/storage):
#   DB_PATH=/app/storage/stories.db
#   VIDEOS_DIR=/app/storage/videos
DB_PATH=
VIDEOS_DIR=
